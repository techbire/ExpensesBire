generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  name          String
  email         String             @unique
  password_hash String
  created_at    DateTime           @default(now())
  
  groups_created Group[]
  memberships    GroupMembership[] @relation("UserMemberships")
  imports        Import[]
  alias_approvals AliasMapping[]   @relation("AliasApprovers")
  audit_logs     AuditLog[]
}

model Group {
  id            String             @id @default(uuid())
  name          String
  base_currency String             @default("INR")
  created_by    String
  created_at    DateTime           @default(now())
  
  creator       User               @relation(fields: [created_by], references: [id])
  memberships   GroupMembership[]
  expenses      Expense[]
  settlements   Settlement[]
  imports       Import[]
  alias_mappings AliasMapping[]
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

model GroupMembership {
  id          String           @id @default(uuid())
  group_id    String
  user_id     String?
  member_name String
  join_date   DateTime
  leave_date  DateTime?
  status      MembershipStatus @default(ACTIVE)
  created_at  DateTime         @default(now())

  group       Group            @relation(fields: [group_id], references: [id])
  user        User?            @relation("UserMemberships", fields: [user_id], references: [id])
  
  expenses_paid Expense[]      @relation("ExpensePayer")
  expense_splits ExpenseSplit[]
  settlements_sent Settlement[] @relation("SettlementSender")
  settlements_received Settlement[] @relation("SettlementReceiver")
  alias_mappings AliasMapping[]
}

enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARE
}

model Expense {
  id                  String       @id @default(uuid())
  group_id            String
  paid_by_member_id   String
  expense_date        DateTime
  description         String
  amount_original     Decimal      @db.Decimal(12, 4)
  currency_original   String
  amount_base         Decimal      @db.Decimal(12, 4)
  base_currency       String
  split_type          SplitType
  note                String?
  source_import_row_id String?     @unique
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  group               Group            @relation(fields: [group_id], references: [id])
  paid_by             GroupMembership  @relation("ExpensePayer", fields: [paid_by_member_id], references: [id])
  splits              ExpenseSplit[]
  source_import_row   ImportRow?       @relation(fields: [source_import_row_id], references: [id])
}

model ExpenseSplit {
  id                 String          @id @default(uuid())
  expense_id         String
  member_id          String
  split_method_value String?
  percentage         Decimal?        @db.Decimal(5, 2)
  share_weight       Decimal?        @db.Decimal(10, 4)
  amount_base        Decimal         @db.Decimal(12, 4)
  final_owed_amount  Decimal         @db.Decimal(12, 4)

  expense            Expense         @relation(fields: [expense_id], references: [id], onDelete: Cascade)
  member             GroupMembership @relation(fields: [member_id], references: [id])
}

model Settlement {
  id                   String          @id @default(uuid())
  group_id             String
  from_member_id       String
  to_member_id         String
  amount               Decimal         @db.Decimal(12, 4)
  currency             String
  amount_base          Decimal         @db.Decimal(12, 4)
  payment_date         DateTime
  note                 String?
  source_import_row_id String?         @unique
  created_at           DateTime        @default(now())

  group                Group           @relation(fields: [group_id], references: [id])
  from_member          GroupMembership @relation("SettlementSender", fields: [from_member_id], references: [id])
  to_member            GroupMembership @relation("SettlementReceiver", fields: [to_member_id], references: [id])
  source_import_row    ImportRow?      @relation(fields: [source_import_row_id], references: [id])
}

enum ImportStatus {
  PENDING
  REVIEWING
  COMPLETED
  FAILED
}

model Import {
  id           String        @id @default(uuid())
  group_id     String
  uploaded_by  String
  file_name    String
  file_hash    String
  status       ImportStatus  @default(PENDING)
  total_rows   Int           @default(0)
  valid_rows   Int           @default(0)
  anomaly_rows Int           @default(0)
  created_at   DateTime      @default(now())

  group        Group         @relation(fields: [group_id], references: [id])
  uploader     User          @relation(fields: [uploaded_by], references: [id])
  rows         ImportRow[]
  anomalies    ImportAnomaly[]
}

enum RowStatus {
  VALID
  ANOMALY
  RESOLVED
  IGNORED
}

enum RowAction {
  NONE
  IMPORTED
  MODIFIED
  CONVERTED_TO_SETTLEMENT
  DISCARDED
}

model ImportRow {
  id               String       @id @default(uuid())
  import_id        String
  row_number       Int
  raw_payload      Json
  parsed_status    RowStatus    @default(VALID)
  action_taken     RowAction    @default(NONE)
  resolved_payload Json?
  created_at       DateTime     @default(now())

  import_file      Import       @relation(fields: [import_id], references: [id], onDelete: Cascade)
  anomalies        ImportAnomaly[]
  expense          Expense?
  settlement       Settlement?
}

enum AnomalyType {
  MISSING_DATA
  FORMATTING
  DUPLICATE
  ALIAS
  SPLIT_CONFLICT
  MEMBERSHIP
  SETTLEMENT
  NEGATIVE_AMOUNT
  ZERO_AMOUNT
  FOREIGN_CURRENCY
  AMBIGUOUS_DATE
}

enum Severity {
  WARNING
  ERROR
}

model ImportAnomaly {
  id               String       @id @default(uuid())
  import_id        String
  row_id           String
  anomaly_type     AnomalyType
  severity         Severity
  description      String
  detected_rule    String
  final_action     String?
  user_decision    String?
  created_at       DateTime     @default(now())

  import_file      Import       @relation(fields: [import_id], references: [id], onDelete: Cascade)
  row              ImportRow    @relation(fields: [row_id], references: [id], onDelete: Cascade)
}

model AliasMapping {
  id                  String       @id @default(uuid())
  group_id            String
  raw_name            String
  canonical_member_id String
  approved_by         String
  approved_at         DateTime     @default(now())

  group               Group           @relation(fields: [group_id], references: [id])
  canonical_member    GroupMembership @relation(fields: [canonical_member_id], references: [id])
  approver            User            @relation("AliasApprovers", fields: [approved_by], references: [id])
}

model ExchangeRate {
  id             String   @id @default(uuid())
  base_currency  String
  quote_currency String
  rate           Decimal  @db.Decimal(10, 6)
  rate_date      DateTime
  created_at     DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(uuid())
  actor_user_id String
  entity_type  String
  entity_id    String
  action       String
  before_state Json?
  after_state  Json?
  created_at   DateTime @default(now())

  actor        User     @relation(fields: [actor_user_id], references: [id])
}
